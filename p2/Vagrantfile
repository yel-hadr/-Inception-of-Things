Vagrant.configure("2") do |config|
  config.vm.box = "generic/debian12"

  # Keep the default mount available because setup_server.sh applies manifests from /vagrant/confs.
  config.vm.synced_folder ".", "/vagrant"

  config.vm.define "yelhadrS" ,  primary: true do |yelhadrS|
    yelhadrS.vm.hostname = "yelhadrS"
    yelhadrS.vm.network "private_network", ip: "192.168.56.110"

    yelhadrS.vm.provider "virtualbox" do |vb|
      vb.name = "yelhadrS-p2"
      vb.memory = 2048
      vb.cpus = 2
      # Keep headless startup lean/stable on WSL + VirtualBox hosts.
      vb.customize ["modifyvm", :id, "--vrde", "off"]
      vb.customize ["modifyvm", :id, "--recording", "off"]
      vb.customize ["modifyvm", :id, "--graphicscontroller", "vmsvga"]
      vb.customize ["modifyvm", :id, "--audio-enabled", "off"]
    end
    yelhadrS.vm.provision "shell", path: "scripts/setup_server.sh"

  end
end
